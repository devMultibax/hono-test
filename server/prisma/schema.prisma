generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  active
  inactive
}

enum Role {
  USER
  ADMIN
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  RESET_PASSWORD
  CHANGE_PASSWORD
}

enum UpdateType {
  FEATURE
  BUGFIX
  IMPROVEMENT
  SECURITY
  OTHER
}

model Department {
  id            Int       @id @default(autoincrement())
  name          String    @unique @db.VarChar(100)
  status        Status    @default(active)
  createdAt     DateTime  @default(now())
  createdBy     String    @db.VarChar(100)
  createdByName String    @default("") @db.VarChar(200)
  updatedAt     DateTime?
  updatedBy     String?   @db.VarChar(100)
  updatedByName String?   @db.VarChar(200)

  sections        Section[]
  userDepartments UserDepartment[]

  @@index([status])
  @@index([createdAt])
  @@map("department")
}

model Section {
  id            Int       @id @default(autoincrement())
  departmentId  Int
  name          String    @db.VarChar(100)
  status        Status    @default(active)
  createdAt     DateTime  @default(now())
  createdBy     String    @db.VarChar(100)
  createdByName String    @default("") @db.VarChar(200)
  updatedAt     DateTime?
  updatedBy     String?   @db.VarChar(100)
  updatedByName String?   @db.VarChar(200)

  department      Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userDepartments UserDepartment[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt])
  @@map("section")
}

model User {
  id                Int       @id @default(autoincrement())
  username          String    @unique @db.Char(6)
  password          String    @db.VarChar(255)
  firstName         String    @db.VarChar(100)
  lastName          String    @db.VarChar(100)
  email             String?   @db.VarChar(255)
  tel               String?   @db.Char(10)
  role              Role      @default(USER)
  status            Status    @default(active)
  createdAt         DateTime  @default(now())
  createdBy         String    @db.VarChar(100)
  createdByName     String    @default("") @db.VarChar(200)
  updatedAt         DateTime?
  updatedBy         String?   @db.VarChar(100)
  updatedByName     String?   @db.VarChar(200)
  lastLoginAt       DateTime?
  isDefaultPassword Boolean   @default(false)
  tokenVersion      Int       @default(0)

  departments UserDepartment[]

  @@index([username])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("user")
}

model UserDepartment {
  id           Int     @id @default(autoincrement())
  userId       Int
  departmentId Int
  sectionId    Int?
  isPrimary    Boolean @default(false)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  section    Section?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@index([sectionId])
  @@map("user_department")
}

model UserLog {
  id            Int        @id @default(autoincrement())
  username      String     @db.Char(6)
  firstName     String     @db.VarChar(100)
  lastName      String     @db.VarChar(100)
  department              String     @db.VarChar(100)
  section                 String     @db.VarChar(100)
  additionalDepartments   String?    @db.VarChar(500)
  email         String?    @db.VarChar(255)
  tel           String?    @db.Char(10)
  role          Role       @default(USER)
  status        Status     @default(active)
  createdAt     DateTime   @default(now())
  createdBy     String     @db.VarChar(100)
  createdByName String     @default("") @db.VarChar(200)
  updatedAt     DateTime?
  updatedBy     String?    @db.VarChar(100)
  updatedByName String?    @db.VarChar(200)
  actionType    ActionType
  actionAt      DateTime   @default(now())

  @@index([username])
  @@index([actionType])
  @@index([actionAt])
  @@map("user_log")
}

model Changelog {
  id            Int        @id @default(autoincrement())
  title         String     @db.VarChar(200)
  description   String?    @db.Text
  updateType    UpdateType @default(OTHER)
  gitRef        String?    @db.VarChar(100)
  updatedDate   DateTime
  createdAt     DateTime   @default(now())
  createdBy     String     @db.VarChar(100)
  createdByName String     @default("") @db.VarChar(200)
  updatedAt     DateTime?
  updatedBy     String?    @db.VarChar(100)
  updatedByName String?    @db.VarChar(200)

  @@index([updateType])
  @@index([updatedDate])
  @@index([createdAt])
  @@map("update_log")
}

model SystemSetting {
  id            Int       @id @default(autoincrement())
  key           String    @unique @db.VarChar(100)
  value         String    @default("false") @db.Text
  description   String?   @db.VarChar(500)
  updatedAt     DateTime?
  updatedBy     String?   @db.VarChar(100)
  updatedByName String?   @db.VarChar(200)

  @@index([key])
  @@map("system_setting")
}
